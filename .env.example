# ========================================
# Production Environment Variables — Railway
# ========================================
# These are set via Railway dashboard or CLI:
#   railway variables set KEY=VALUE
#
# Sensitive values should be set as secrets in Railway:
#   railway variables set DATABASE_URL=postgresql://...
#
# For CI/CD via GitHub Actions, add values to
# GitHub repo → Settings → Secrets and variables → Actions

# --- Database ---
# Railway auto-provisions DATABASE_URL when PostgreSQL is added.
# If using an external database, set this manually.
DATABASE_URL= 

# --- Authentication ---
# 32-character random string for NextAuth.js token signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=Rnkv7u1NPvLX3mypwJfE9a0VgkWe0+r4YLDgOANF6Pw=
# REQUIRED for Google OAuth. Must match the deployment URL exactly.
# Local dev: http://localhost:3000
# Production: https://your-app.up.railway.app
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for social sign-in)
# Get credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google to authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Payments (Mock Mode — v1) ---
# Set MOCK_PAYMENTS=true to bypass real Stripe processing
MOCK_PAYMENTS=true
STRIPE_SECRET_KEY=

# --- Email (Mock Mode — v1) ---
RESEND_API_KEY=

# --- File Uploads (Cloudflare R2) ---
# S3-compatible API — get these from Cloudflare R2 dashboard
# 1. Create R2 bucket named "ecommerce"
# 2. Create API token with Object Read & Write permissions
# 3. Get endpoint from bucket's "S3 API" tab
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=ecommerce
# R2_PUBLIC_URL=https://pub-<hash>.r2.dev (domain connected to bucket)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce
R2_PUBLIC_URL=

# --- Mercantil Banco Payment Gateway ---
# Get these from Mercantil Banco after suscription (apisupport@mercantilbanco.com)
DOMINIO_API_SECRET=
DOMINIO_API_KEY=
MERCHANT_RIF=J-99999999-9
INTEGRATOR_ID=31
MERCANTIL_APP=zewar
MERCANTIL_API_URL=https://apimbu.mercantilbanco.com/mercantil-banco/sandbox/v1/payment
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Setup ---
# Token to authorize POST /api/setup (creates admin on fresh deployments)
# Generate: openssl rand -base64 32
SETUP_TOKEN=
