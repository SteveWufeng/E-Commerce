# ========================================
# Environment Variables
# Copy to .env.local and fill in values
# ========================================

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce_mvp?schema=public"

# --- Authentication ---
NEXTAUTH_SECRET="change-this-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Payments (Mock Mode) ---
# Set MOCK_PAYMENTS=true to bypass real payment processing
MOCK_PAYMENTS=true
STRIPE_SECRET_KEY="sk_test_mock_key"
STRIPE_PUBLISHABLE_KEY="pk_test_mock_key"

# --- Email Notifications ---
RESEND_API_KEY="re_mock_key"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# --- SMS Notifications ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Analytics ---
# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# --- App ---
NEXT_PUBLIC_APP_NAME="E-Commerce MVP"
NEXT_PUBLIC_STORE_NAME="My Store"
NEXT_PUBLIC_STORE_ADDRESS="123 Main St, City, State"

# --- Admin ---
# Single admin email for the store owner
ADMIN_EMAIL="admin@store.com"

# --- Server ---
NODE_ENV=development
PORT=3000
