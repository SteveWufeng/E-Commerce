# ========================================
# Production Environment Variables — Railway
# ========================================
# These are set via Railway dashboard or CLI:
#   railway variables set KEY=VALUE
#
# Sensitive values should be set as secrets in Railway:
#   railway variables set DATABASE_URL=postgresql://...
#
# For CI/CD via GitHub Actions, add values to
# GitHub repo → Settings → Secrets and variables → Actions

# --- Database ---
# Railway auto-provisions DATABASE_URL when PostgreSQL is added.
# If using an external database, set this manually.
DATABASE_URL=

# --- Authentication ---
# 32-character random string for NextAuth.js token signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# REQUIRED for Google OAuth. Must match your Railway app URL exactly.
# Set this in Railway dashboard: https://your-app.up.railway.app
NEXTAUTH_URL=

# Google OAuth (for social sign-in)
# Get credentials at https://console.cloud.google.com/apis/credentials
# Add https://your-app.up.railway.app/api/auth/callback/google to authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Payments (Mock Mode — v1) ---
# Set MOCK_PAYMENTS=true to bypass real Stripe processing
MOCK_PAYMENTS=true
STRIPE_SECRET_KEY=

# --- Email (Mock Mode — v1) ---
RESEND_API_KEY=

# --- File Uploads (Cloudflare R2) ---
# S3-compatible object storage for product images
# See SETUP.md for step-by-step R2 configuration instructions
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce
R2_PUBLIC_URL=

# --- Mercantil Banco Payment Gateway ---
# Get these from Mercantil Banco after suscription (apisupport@mercantilbanco.com)
DOMINIO_API_SECRET=
DOMINIO_API_KEY=
MERCHANT_RIF=
INTEGRATOR_ID=31
# The bank provides the payment page URL. Set this for direct redirect:
MERCANTIL_REDIRECT_URL=
# OR use the API approach (set API URL and app name):
# MERCANTIL_API_URL=https://apimbu.mercantilbanco.com/mercantil-banco/prod/v1/payment
# MERCANTIL_APP=zewar
NEXT_PUBLIC_BASE_URL=

# --- Setup ---
# Token to authorize POST /api/setup (creates admin on fresh deployments)
# Generate: openssl rand -base64 32, set both here and in Railway dashboard
SETUP_TOKEN=
