# ========================================
# Production Environment Variables
# ========================================
# These are set via `npx wrangler secret put <NAME>`
# (Per D-09: Cloudflare Workers secrets management)
#
# Set each before first deploy:
#   npx wrangler secret put DATABASE_URL
#   ... etc
#
# GitHub Actions references these as repository secrets
# for CI/CD injection (Per D-10)

## Setting Production Secrets
#
# 1. Authenticate: npx wrangler login
# 2. Set each secret:
#    npx wrangler secret put DATABASE_URL
#    npx wrangler secret put NEXTAUTH_SECRET
#    npx wrangler secret put STRIPE_SECRET_KEY
#    npx wrangler secret put RESEND_API_KEY
# 3. Verify: npx wrangler secret list
#
# For CI/CD, also add to GitHub repo secrets:
#    Settings → Secrets and variables → Actions → New repository secret
#    Add: DATABASE_URL, NEXTAUTH_SECRET, CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID

# --- Database ---
# Supabase PostgreSQL connection string
# Source: Supabase Dashboard → Project Settings → Database → Connection String (Transaction pooler)
# Format: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Authentication ---
# 32-character random string for NextAuth.js token signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Payments (Mock Mode — v1) ---
# Set MOCK_PAYMENTS=true to bypass real Stripe processing
MOCK_PAYMENTS=true
STRIPE_SECRET_KEY=

# --- Email (Mock Mode — v1) ---
RESEND_API_KEY=

# --- Cloudflare API (CI/CD only, not set via wrangler secrets) ---
# Cloudflare API Token with Workers edit permission
# Source: https://dash.cloudflare.com/profile/api-tokens
# Set in GitHub repo → Settings → Secrets and variables → Actions
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
